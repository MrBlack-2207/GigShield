# gigshield/.env.example
# Copy this file to .env and fill in your values
# Never commit .env to git

# ── PostgreSQL ──────────────────────────────
POSTGRES_USER=gigshield
POSTGRES_PASSWORD=gigshield_dev
POSTGRES_DB=gigshield_db
POSTGRES_HOST=postgres
POSTGRES_PORT=5432

# Constructed automatically by backend/app/config.py — do not edit
DATABASE_URL=postgresql://gigshield:gigshield_dev@postgres:5432/gigshield_db

# ── Redis ────────────────────────────────────
REDIS_HOST=redis
REDIS_PORT=6379
REDIS_URL=redis://redis:6379/0

# ── App ──────────────────────────────────────
APP_ENV=development          # development | production
SECRET_KEY=change_this_to_a_random_32_char_string
CORS_ORIGINS=http://localhost:3000

# ── Insurance constants (locked from our design) ─
WORKING_HOURS_PER_DAY=10
COVERAGE_RATIO=0.30
CORRELATION_LOAD=1.18
LOADING_FACTOR=1.25
ADMIN_FEE_INR=5.00
SCHEDULER_INTERVAL_MINUTES=15

# ── Mock flags ───────────────────────────────
# Set to true = use mock adapters (hackathon mode)
# Set to false = use real API adapters (production)
USE_MOCK_WEATHER=true
USE_MOCK_TRAFFIC=true
USE_MOCK_AQI=true
USE_MOCK_PAYMENT=true
