{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "ds_disruption_severity_event_row",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "event_id",
    "zone_id",
    "season_index",
    "start_hour",
    "day_of_week",
    "max_rain_norm",
    "max_outage_norm",
    "max_traffic_norm",
    "max_aqi_norm",
    "mean_rain_norm",
    "mean_traffic_norm",
    "event_flags_active_count",
    "max_zdi",
    "mean_zdi",
    "zdi_above_50_ratio",
    "zdi_above_75_ratio",
    "conditional_payout_rate"
  ],
  "properties": {
    "event_id": {"type": "string"},
    "zone_id": {"type": "string"},
    "season_index": {"type": "integer", "minimum": 1, "maximum": 4},
    "start_hour": {"type": "integer", "minimum": 0, "maximum": 23},
    "day_of_week": {"type": "integer", "minimum": 0, "maximum": 6},
    "max_rain_norm": {"type": "number", "minimum": 0, "maximum": 100},
    "max_outage_norm": {"type": "number", "minimum": 0, "maximum": 100},
    "max_traffic_norm": {"type": "number", "minimum": 0, "maximum": 100},
    "max_aqi_norm": {"type": "number", "minimum": 0, "maximum": 100},
    "mean_rain_norm": {"type": "number", "minimum": 0, "maximum": 100},
    "mean_traffic_norm": {"type": "number", "minimum": 0, "maximum": 100},
    "event_flags_active_count": {"type": "integer", "minimum": 0},
    "max_zdi": {"type": "number", "minimum": 0, "maximum": 100},
    "mean_zdi": {"type": "number", "minimum": 0, "maximum": 100},
    "zdi_above_50_ratio": {"type": "number", "minimum": 0, "maximum": 1},
    "zdi_above_75_ratio": {"type": "number", "minimum": 0, "maximum": 1},
    "conditional_payout_rate": {"type": "number", "minimum": 0, "maximum": 1},
    "payout_tier_class": {"type": "integer", "enum": [0, 1, 2]}
  }
}
